{
	"diff_view_style": "unified",
 "git_panel": {
		"tree_view": false
	},
	"language_models": {
		"openai": {
			"api_url": "https://api.openai.com/v1",
			"available_models": [
				{
					"name": "gpt-4.1-mini",
					"max_tokens": 200000,
					"max_output_tokens": 32000
				}
			]
		}
	},
	"icon_theme": "Light Charmed Icons",
	"session": {
		"trust_all_worktrees": true
	},
	"vim_mode": true,
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"base_keymap": "Cursor",
	"agent": {
		"inline_assistant_model": {
			"provider": "openai",
			"model": "gpt-5-codex",
			"enable_thinking": false
		},
		"dock": "left",
		"default_model": {
			"provider": "openai",
			"model": "gpt-4o"
		},
		"model_parameters": []
	},
	"hover_popover_delay": 0,
	"show_signature_help_after_edits": false,
	"zoomed_padding": false,
	"use_system_window_tabs": false,
	"tabs": {
		"file_icons": false,
		"git_status": false
	},
	"preview_tabs": {
		"enable_keep_preview_on_code_navigation": false,
		"enable_preview_from_file_finder": false,
		"enabled": false
	},
	"title_bar": {
		"show_project_items": true,
		"show_branch_name": true,
		"show_branch_icon": false,
		"show_menus": false,
		"show_sign_in": false,
		"show_user_picture": false,
		"show_onboarding_banner": false
	},
	"status_bar": {
		"active_language_button": false,
		"cursor_position_button": false
	},
	"diagnostics": {
		"button": false
	},
	"search": {
		"center_on_match": true,
		"button": false
	},
	"debugger": {
		"button": false
	},
	"edit_predictions": {
		"mode": "eager"
	},
	"vertical_scroll_margin": 30.0,
	"indent_guides": {
		"enabled": false
	},
	"toolbar": {
		"agent_review": false,
		"selections_menu": false,
		"quick_actions": false,
		"breadcrumbs": true
	},
	"minimap": {
		"current_line_highlight": "none",
		"thumb_border": "none",
		"thumb": "hover"
	},
	"scrollbar": {
		"axes": {
			"vertical": false,
			"horizontal": false
		},
		"git_diff": true,
		"cursors": false,
		"show": "never"
	},
	"rounded_selection": false,
	"cursor_shape": "bar",
	"helix_mode": true,
	"theme": "Jellybeans Custom",
	"ui_font_family": "JetBrains Mono",
	"buffer_font_family": "Iosevka Term SS08",
	"ui_font_size": 17.0,
	"buffer_font_size": 16.0,
	"buffer_font_weight": 300.0,
	"buffer_line_height": "standard",
	"ui_font_weight": 300.0,
	"relative_line_numbers": "enabled",
	"soft_wrap": "editor_width",
	"tab_bar": {
		"show_pinned_tabs_in_separate_row": false,
		"show_tab_bar_buttons": false,
		"show_nav_history_buttons": false,
		"show": false
	},
	"terminal": {
		"button": false,
		"dock": "right"
	},
	"inlay_hints": {
		"enabled": false
	},
	"format_on_save": "on",
	"ensure_final_newline_on_save": true,
	"remove_trailing_whitespace_on_save": true,
	"cursor_blink": false,
	"autosave": "off",
	"sticky_scroll": {
		"enabled": true,
		"show": true
	},
	"file_finder": {
		"file_icons": true
	},
	"project_panel": {
		"button": true,
		"dock": "left",
		"default_width": 240
	},
	"git": {
		"inline_blame": {
			"delay_ms": 0,
			"enabled": true
		},
		"git_gutter": "tracked_files"
	},
	"formatter": "auto",
	"languages": {
		"PHP": {
			"language_servers": ["intelephense", "!phpactor"]
		}
	},
	"lsp": {
		"intelephense": {
			"settings": {
				"licenceKey": "007ZC8JVEVM35Z9"
			}
		},
		"phpactor": {
			"disabled": true
		}
	}
}
