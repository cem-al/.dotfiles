[
  {
    "context": "Editor",
    "bindings": {
      "space w": "workspace::SaveAll",
      "space q": "pane::CloseActiveItem",
      "space b": "tab_switcher::ToggleAll",
      "space tab": "pane::AlternateFile",
      "] g": "editor::GoToHunk",
      "[ g": "editor::GoToPreviousHunk",
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",
      "[ [": "pane::GoBack",
      "] ]": "pane::GoForward",
      "space /": "pane::DeploySearch",
      "shift-ctrl-alt-cmd-m": "workspace::ActivateNextPane",
      "shift-ctrl-alt-cmd-b": "git::Blame",
      "shift-ctrl-alt-cmd-o": "outline::Toggle",
      "cmd-shift-w": "pane::SplitRight",
      "cmd-shift-e": "pane::SplitDown",
      "escape escape": "buffer_search::Dismiss"
    }
  }
]
